<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<TabPane tabClosingPolicy="UNAVAILABLE" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.insurance.MainController">
    <tabs>
        <Tab text="Філії">
            <VBox spacing="15">
                <padding>
                    <Insets top="15" right="15" bottom="15" left="15"/>
                </padding>
                <Label text="Список філій" />
                <TableView fx:id="branchTable">
                    <columns>
                        <TableColumn fx:id="branchColName" text="Назва" />
                        <TableColumn fx:id="branchColAddress" text="Адреса" />
                        <TableColumn fx:id="branchColPhone" text="Телефон" />
                    </columns>
                </TableView>
                <GridPane hgap="10" vgap="10">
                    <Label text="Назва філії:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                    <TextField fx:id="tfBranchName" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                    <Label text="Адреса:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                    <TextField fx:id="tfBranchAddress" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                    <Label text="Телефон:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                    <TextField fx:id="tfBranchPhone" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                </GridPane>
                <HBox spacing="15">
                    <Button text="Додати філію" onAction="#handleAddBranch"/>
                    <Button text="Видалити вибрану" onAction="#handleDeleteBranch"/>
                </HBox>
            </VBox>
        </Tab>

        <Tab text="Види страхування">
            <VBox spacing="15">
                <padding>
                    <Insets top="15" right="15" bottom="15" left="15"/>
                </padding>
                <Label text="Види страхування" />
                <TableView fx:id="typeTable">
                    <columns>
                        <TableColumn fx:id="typeColName" text="Назва виду" />
                    </columns>
                </TableView>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="Назва:"/>
                    <TextField fx:id="tfTypeName"/>
                </HBox>
                <HBox spacing="15">
                    <Button text="Додати вид" onAction="#handleAddType"/>
                    <Button text="Видалити вибраний" onAction="#handleDeleteType"/>
                </HBox>
            </VBox>
        </Tab>

        <Tab text="Договори">
            <VBox spacing="15">
                <padding>
                    <Insets top="15" right="15" bottom="15" left="15"/>
                </padding>
                <Label text="Список договорів" />
                <TableView fx:id="contractTable">
                    <columns>
                        <TableColumn fx:id="colContractNum" text="Номер договору" />
                        <TableColumn fx:id="colContractDate" text="Дата" />
                        <TableColumn fx:id="colContractSum" text="Страхова сума" />
                        <TableColumn fx:id="colContractRate" text="Тариф" />
                        <TableColumn fx:id="colContractPremium" text="Премія" />
                        <TableColumn fx:id="colContractBranch" text="Філія" />
                        <TableColumn fx:id="colContractType" text="Вид страхування" />
                    </columns>
                </TableView>
                <GridPane hgap="10" vgap="10">
                    <Label text="Номер договору:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                    <TextField fx:id="tfContractNum" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                    <Label text="Дата укладення:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                    <DatePicker fx:id="dpContractDate" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                    <Label text="Страхова сума:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                    <TextField fx:id="tfContractSum" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                    <Label text="Тарифна ставка:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                    <TextField fx:id="tfContractRate" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
                    <Label text="Філія:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                    <ComboBox fx:id="cbBranch" GridPane.rowIndex="4" GridPane.columnIndex="1"/>
                    <Label text="Вид страхування:" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
                    <ComboBox fx:id="cbType" GridPane.rowIndex="5" GridPane.columnIndex="1"/>
                </GridPane>
                <HBox spacing="15">
                    <Button text="Укласти договір" onAction="#handleAddContract"/>
                    <Button text="Видалити договір" onAction="#handleDeleteContract"/>
                </HBox>
            </VBox>
        </Tab>

        <Tab text="Фінансовий звіт">
            <VBox spacing="20">
                <padding>
                    <Insets top="25" right="25" bottom="25" left="25"/>
                </padding>
                <Label text="Фінансова діяльність компанії" style="-fx-font-size: 24px; -fx-font-weight: bold;" />
                <Button text="Оновити звіт" onAction="#handleRefreshReport"/>
                <Label fx:id="lblTotalSum" text="Загальна страхова сума: 0.00 грн" />
                <Label fx:id="lblTotalPremium" text="Загальна премія: 0.00 грн" />
            </VBox>
        </Tab>
    </tabs>
</TabPane>