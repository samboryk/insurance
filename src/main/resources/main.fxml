<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<TabPane stylesheets="@style.css" tabClosingPolicy="UNAVAILABLE" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="MainController">
    <tabs>
        <Tab text="Філії">
            <VBox spacing="15" alignment="TOP_CENTER">
                <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                <VBox spacing="15" styleClass="card" VBox.vgrow="ALWAYS">
                    <Label text="Список філій" styleClass="header-label"/>
                    <TableView fx:id="branchTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="branchColName" text="Назва" prefWidth="200"/>
                            <TableColumn fx:id="branchColAddress" text="Адреса" prefWidth="300"/>
                            <TableColumn fx:id="branchColPhone" text="Телефон" prefWidth="150"/>
                        </columns>
                    </TableView>
                    <GridPane hgap="15" vgap="15">
                        <Label text="Назва:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                        <TextField fx:id="tfBranchName" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                        <Label text="Адреса:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                        <TextField fx:id="tfBranchAddress" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                        <Label text="Телефон:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                        <TextField fx:id="tfBranchPhone" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                    </GridPane>
                    <HBox spacing="15">
                        <Button text="Додати філію" onAction="#handleAddBranch" styleClass="primary-button"/>
                        <Button text="Видалити" onAction="#handleDeleteBranch" styleClass="danger-button"/>
                    </HBox>
                </VBox>
            </VBox>
        </Tab>
        <Tab text="Види страхування">
            <VBox spacing="15" alignment="TOP_CENTER">
                <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                <VBox spacing="15" styleClass="card" VBox.vgrow="ALWAYS">
                    <Label text="Види страхування" styleClass="header-label"/>
                    <TableView fx:id="typeTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="typeColName" text="Назва виду" prefWidth="400"/>
                        </columns>
                    </TableView>
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label text="Назва:"/>
                        <TextField fx:id="tfTypeName" prefWidth="250"/>
                    </HBox>
                    <HBox spacing="15">
                        <Button text="Додати вид" onAction="#handleAddType" styleClass="primary-button"/>
                        <Button text="Видалити" onAction="#handleDeleteType" styleClass="danger-button"/>
                    </HBox>
                </VBox>
            </VBox>
        </Tab>
        <Tab text="Договори">
            <VBox spacing="15" alignment="TOP_CENTER">
                <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                <VBox spacing="15" styleClass="card" VBox.vgrow="ALWAYS">
                    <Label text="Список договорів" styleClass="header-label"/>
                    <TableView fx:id="contractTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colContractNum" text="№" prefWidth="100"/>
                            <TableColumn fx:id="colContractDate" text="Дата" prefWidth="100"/>
                            <TableColumn fx:id="colContractSum" text="Сума" prefWidth="100"/>
                            <TableColumn fx:id="colContractRate" text="Тариф" prefWidth="80"/>
                            <TableColumn fx:id="colContractPremium" text="Премія" prefWidth="100"/>
                            <TableColumn fx:id="colContractBranch" text="Філія" prefWidth="150"/>
                            <TableColumn fx:id="colContractType" text="Вид" prefWidth="150"/>
                        </columns>
                    </TableView>
                    <GridPane hgap="15" vgap="15">
                        <Label text="№ договору:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                        <TextField fx:id="tfContractNum" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                        <Label text="Дата:" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                        <DatePicker fx:id="dpContractDate" GridPane.rowIndex="0" GridPane.columnIndex="3"/>
                        <Label text="Сума:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                        <TextField fx:id="tfContractSum" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                        <Label text="Тариф:" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
                        <TextField fx:id="tfContractRate" GridPane.rowIndex="1" GridPane.columnIndex="3"/>
                        <Label text="Філія:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                        <ComboBox fx:id="cbBranch" GridPane.rowIndex="2" GridPane.columnIndex="1" prefWidth="200"/>
                        <Label text="Вид:" GridPane.rowIndex="2" GridPane.columnIndex="2"/>
                        <ComboBox fx:id="cbType" GridPane.rowIndex="2" GridPane.columnIndex="3" prefWidth="200"/>
                    </GridPane>
                    <HBox spacing="15">
                        <Button text="Укласти договір" onAction="#handleAddContract" styleClass="primary-button"/>
                        <Button text="Видалити" onAction="#handleDeleteContract" styleClass="danger-button"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="Оновити" onAction="#handleRefresh" styleClass="secondary-button"/>
                    </HBox>
                </VBox>
            </VBox>
        </Tab>
        <Tab text="Фінансовий звіт">
            <VBox spacing="20">
                <padding><Insets top="25" right="25" bottom="25" left="25"/></padding>
                <Label text="Фінансова діяльність компанії" styleClass="header-label" />
                <Button text="Оновити звіт" onAction="#handleRefreshReport" styleClass="secondary-button"/>
                <Separator/>
                <Label fx:id="lblTotalSum" text="Загальна страхова сума: 0.00 грн" style="-fx-font-size: 16px;"/>
                <Label fx:id="lblTotalPremium" text="Загальна премія: 0.00 грн" style="-fx-font-size: 16px;"/>
            </VBox>
        </Tab>
    </tabs>
</TabPane>