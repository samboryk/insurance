<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<TabPane stylesheets="@style.css" tabClosingPolicy="UNAVAILABLE" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="MainController">
    <tabs>
        <Tab text="Викладачі">
            <VBox spacing="15" alignment="TOP_CENTER">
                <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

                <VBox spacing="15" styleClass="card" VBox.vgrow="ALWAYS">
                    <Label text="Список викладачів кафедри" styleClass="header-label"/>

                    <TableView fx:id="teacherTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colTLastName" text="Прізвище" prefWidth="120"/>
                            <TableColumn fx:id="colTFirstName" text="Ім'я" prefWidth="100"/>
                            <TableColumn fx:id="colTMiddleName" text="По батькові" prefWidth="120"/>
                            <TableColumn fx:id="colTDegree" text="Ступінь" prefWidth="120"/>
                            <TableColumn fx:id="colTPosition" text="Посада" prefWidth="120"/>
                            <TableColumn fx:id="colTExperience" text="Стаж (років)" prefWidth="80"/>
                        </columns>
                    </TableView>

                    <Separator/>

                    <GridPane hgap="15" vgap="15">
                        <Label text="Прізвище:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                        <TextField fx:id="tfLastName" GridPane.rowIndex="0" GridPane.columnIndex="1" prefWidth="200"/>
                        <Label text="Ім'я:" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                        <TextField fx:id="tfFirstName" GridPane.rowIndex="0" GridPane.columnIndex="3" prefWidth="200"/>

                        <Label text="По батькові:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                        <TextField fx:id="tfMiddleName" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                        <Label text="Ступінь:" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
                        <TextField fx:id="tfDegree" GridPane.rowIndex="1" GridPane.columnIndex="3"/>

                        <Label text="Посада:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                        <TextField fx:id="tfPosition" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                        <Label text="Стаж (роки):" GridPane.rowIndex="2" GridPane.columnIndex="2"/>
                        <TextField fx:id="tfExperience" GridPane.rowIndex="2" GridPane.columnIndex="3"/>
                    </GridPane>

                    <HBox spacing="15" alignment="CENTER_LEFT">
                        <padding><Insets top="10" /></padding>
                        <Button text="Додати викладача" onAction="#handleAddTeacher" styleClass="primary-button"/>
                        <Button text="Видалити вибраного" onAction="#handleDeleteTeacher" styleClass="danger-button"/>
                        <Region HBox.hgrow="ALWAYS" />
                        <Button text="Оновити дані" onAction="#handleRefresh" styleClass="secondary-button"/>
                    </HBox>
                </VBox>
            </VBox>
        </Tab>

        <Tab text="Предмети">
            <VBox spacing="15" alignment="TOP_CENTER">
                <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

                <VBox spacing="15" styleClass="card" VBox.vgrow="ALWAYS">
                    <Label text="Перелік навчальних дисциплін" styleClass="header-label"/>

                    <TableView fx:id="subjectTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colSubName" text="Назва предмету" prefWidth="400"/>
                            <TableColumn fx:id="colSubHours" text="Кількість годин" prefWidth="120"/>
                        </columns>
                    </TableView>

                    <Separator/>

                    <GridPane hgap="15" vgap="15">
                        <Label text="Назва дисципліни:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                        <TextField fx:id="tfSubName" GridPane.rowIndex="0" GridPane.columnIndex="1" prefWidth="300"/>
                        <Label text="Всього годин:" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                        <TextField fx:id="tfSubHours" GridPane.rowIndex="0" GridPane.columnIndex="3" prefWidth="100"/>
                    </GridPane>

                    <HBox spacing="15" alignment="CENTER_LEFT">
                        <padding><Insets top="10" /></padding>
                        <Button text="Додати предмет" onAction="#handleAddSubject" styleClass="primary-button"/>
                        <Button text="Видалити предмет" onAction="#handleDeleteSubject" styleClass="danger-button"/>
                        <Region HBox.hgrow="ALWAYS" />
                        <Button text="Оновити дані" onAction="#handleRefresh" styleClass="secondary-button"/>
                    </HBox>
                </VBox>
            </VBox>
        </Tab>

        <Tab text="Навантаження">
            <VBox spacing="15" alignment="TOP_CENTER">
                <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

                <VBox spacing="15" styleClass="card" VBox.vgrow="ALWAYS">
                    <Label text="Розподіл навантаження на семестр" styleClass="header-label"/>

                    <TableView fx:id="workloadTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colWTeacher" text="Викладач" prefWidth="250"/>
                            <TableColumn fx:id="colWSubject" text="Предмет" prefWidth="300"/>
                            <TableColumn fx:id="colWGroup" text="Група" prefWidth="120"/>
                        </columns>
                    </TableView>

                    <Separator/>

                    <GridPane hgap="15" vgap="15">
                        <Label text="Виберіть викладача:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                        <ComboBox fx:id="cbTeacher" GridPane.rowIndex="0" GridPane.columnIndex="1" prefWidth="250"/>

                        <Label text="Виберіть предмет:" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                        <ComboBox fx:id="cbSubject" GridPane.rowIndex="0" GridPane.columnIndex="3" prefWidth="250"/>

                        <Label text="Номер групи:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                        <TextField fx:id="tfGroup" GridPane.rowIndex="1" GridPane.columnIndex="1" prefWidth="250"/>
                    </GridPane>

                    <HBox spacing="15" alignment="CENTER_LEFT">
                        <padding><Insets top="10" /></padding>
                        <Button text="Призначити навантаження" onAction="#handleAddWorkload" styleClass="primary-button"/>
                        <Button text="Видалити запис" onAction="#handleDeleteWorkload" styleClass="danger-button"/>
                        <Region HBox.hgrow="ALWAYS" />
                        <Button text="Оновити дані" onAction="#handleRefresh" styleClass="secondary-button"/>
                    </HBox>
                </VBox>
            </VBox>
        </Tab>
    </tabs>
</TabPane>